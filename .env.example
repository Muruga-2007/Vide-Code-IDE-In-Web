# Copy this file to backend/.env and fill in your values

# Required: Google AI Studio API key
# Get yours at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Allowed frontend origins (comma-separated JSON array)
CORS_ORIGINS=["http://localhost:3000"]

# Max tokens allowed per pipeline session (hard cap)
TOKEN_BUDGET=40000

# Timeout per stage in seconds
STAGE_TIMEOUT_SEC=90
